# ── App ────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=sqlite+aiosqlite:///./app.db
DRY_RUN=true   # set to false to post live

# ── Mastodon ───────────────────────────────────────────────────────────────────
# Get from: your instance → Settings → Development → New Application
# Required scopes: write:statuses, write:media
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=

# ── Bluesky ────────────────────────────────────────────────────────────────────
# Get from: Settings → Privacy and Security → App Passwords
BLUESKY_HANDLE=yourhandle.bsky.social
BLUESKY_APP_PASSWORD=

# ── Telegram ───────────────────────────────────────────────────────────────────
# Bot token from @BotFather → /newbot
# Chat ID from @userinfobot after adding bot to your channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── LinkedIn ───────────────────────────────────────────────────────────────────
# App from: https://developer.linkedin.com/apps
# Required product: Share on LinkedIn
# Run OAuth flow at: http://localhost:8080/auth/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8080/auth/linkedin/callback
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_PAGE_URN=

# ── Facebook ───────────────────────────────────────────────────────────────────
# App from: https://developers.facebook.com
# Use case: Manage everything on your Page
# Permissions: pages_manage_posts, pages_read_engagement
# Get Page token via Graph API Explorer → /me/accounts → data[0].access_token
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Instagram ──────────────────────────────────────────────────────────────────
# Requires Instagram Business account linked to Facebook Page
# Account ID from Graph API: /{page_id}?fields=instagram_business_account
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# ── Dashboard Auth ─────────────────────────────────────────────────────────────
# Generate secret key: python3 -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_USERNAME=your_username
DASHBOARD_PASSWORD=your_strong_password
SECRET_KEY=
